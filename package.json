{
  "name": "ax-calculator",
  "version": "2.2.6",
  "description": "Complex Math Calculator",
  "types": "dist/types",
  "scripts": {
    "test": "jest --config jest.config.json",
    "build": "tsc -p tsconfig.json",
    "clean": "tsc --build --clean"
  },
  "keywords": [
    "calculator",
    "equations",
    "math",
    "trigonometry",
    "algebra",
    "geometry",
    "fractions",
    "percentages",
    "operations",
    "linear",
    "regression",
    "chemistry",
    "elements",
    "validator",
    "clock",
    "time",
    "date"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/main.js",
      "require": "./dist/cjs/main.js",
      "default": "./dist/esm/main.js"
    }
  },
  "main": "./dist/cjs/main.js",
  "module": "./dist/esm/main.js",
  "author": "Donatto Minaya",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donatto22/ax-calculator.git"
  },
  "bugs": {
    "url": "https://github.com/donatto22/ax-calculator/issues"
  },
  "homepage": "https://github.com/donatto22/ax-calculator#readme",
  "devDependencies": {
    "jest": "^27.5.1",
    "ts-jest": "^27.1.4",
    "user-agent-data-types": "^0.2.0"
  }
}
