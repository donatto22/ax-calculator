{
    "compilerOptions": {
      "target": "ES5",
      "lib": ["ES5" ,"ES6", "DOM"],             
      "module": "CommonJS",
      "moduleResolution": "node",
      "outDir": "./dist/cjs",
      "declaration": true,
      "declarationDir": "dist/types",
      "sourceMap": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "skipLibCheck": true
    },
    "include": ["src/**/*.ts"]
}