{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["ES5" ,"ES6", "DOM"],             
    "module": "ESNEXT",
    "moduleResolution": "node",
    "outDir": "./dist/esm",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
